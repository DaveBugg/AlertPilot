# =============================================================================
# AlertPilot — Environment Configuration
# =============================================================================
# Copy this file:  cp .env.example .env
# Edit values, then: docker compose up -d
# =============================================================================

# --- Domain & TLS ---
# Caddy auto-obtains Let's Encrypt certificate for this domain.
# Use "localhost" for local dev (HTTP only, no TLS).
DOMAIN=alerts.your.host

# --- Custom Port ---
# Leave empty for standard ports (80 HTTP / 443 HTTPS).
# Set to a custom port to avoid conflicts with existing services.
#
# Examples:
#   WEB_PORT=50443  → https://alerts.your.host:50443 (with real domain)
#   WEB_PORT=50080  → http://localhost:50080 (local dev, DOMAIN=localhost)
#
# Port 80 is always bound for ACME HTTP challenge (Let's Encrypt).
WEB_PORT=

# --- ntfy ---
# Base URL ntfy uses for generating links. Must NOT contain a path — ntfy
# doesn't support sub-paths. Caddy strips /ntfy/ before proxying.
NTFY_BASE_URL=https://alerts.your.host

# Topic names (change to anything you want, just match in PWA config).
NTFY_OPS_TOPIC=ops-alerts
NTFY_DEV_TOPIC=dev-alerts

# Bot token for runner → ntfy communication.
# Generate with: docker compose exec ntfy ntfy token add bot
NTFY_BOT_TOKEN=tk_your_bot_token_here

# --- Runner ---
# Bearer token for machine-to-machine access (scripts, monitoring agents).
# The PWA uses JWT tokens — this is for server-side callers only.
RUNNER_SECRET=change-this-to-a-strong-secret

# Optional: protect webhook endpoint with a shared secret.
# External services must include header: X-Webhook-Secret: <value>
# Leave empty to accept all webhook calls (not recommended for public servers).
WEBHOOK_SECRET=

# Comma-separated list of services that restart/scale actions are allowed to touch.
SERVICE_WHITELIST=nginx,api,worker,postgres,redis

# Timeout for action execution (seconds).
ACTION_TIMEOUT=30

# Path to runbook scripts inside the container.
RUNBOOKS_DIR=/app/runbooks

# --- Web Push (VAPID) ---
# Required for background push notifications when the app is closed.
# Generate keys: docker compose exec ntfy ntfy webpush keys
# Then paste here:
NTFY_WEB_PUSH_PUBLIC_KEY=
NTFY_WEB_PUSH_PRIVATE_KEY=

# --- PWA build-time config ---
# Baked into the JS bundle so users don't need to type URLs on first open.
# Must be the public-facing URLs (same domain users access).
VITE_NTFY_URL=https://alerts.your.host/ntfy
VITE_RUNNER_URL=https://alerts.your.host/runner

# --- Auth (JWT) ---
# Auto-generated on first run if empty. Set manually for multi-instance setups.
JWT_SECRET=
# Session duration in days (default: 30).
JWT_EXPIRY_DAYS=30
